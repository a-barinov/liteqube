#!/bin/sh

LINE=$(cat /home/user/.dbus/session-bus/* | grep DBUS_SESSION_BUS_ADDRESS= | tail -n 1)
BUS=${LINE:25}
sudo -u user /bin/sh -c "DISPLAY=:0 DBUS_SESSION_BUS_ADDRESS=${BUS} dbus-send --dest=org.naquadah.awesome.awful --type=method_call --print-reply / org.naquadah.awesome.awful.Remote.Eval string:\"require('naughty').notify({ title = '$QREXEC_REMOTE_DOMAIN', text = '${1//_/ }' })\"" 1>/dev/null 2>&1
